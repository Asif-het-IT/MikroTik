# MTK MikroTik Monitoring Pack (ROS 6.49.19 - parse-safe)

/system scheduler remove [find where name~"MTK_SCH_|HET_"]
/system script remove [find where name~"MTK_|HET_"]
/system script environment remove [find where name~"MTK|HET"]

/system script add name=MTK_CONFIG policy=read,write,test source=":global MTKURL \"https://script.google.com/macros/s/AKfycbx9-NRt1Cdj2kR4nijgH2aaGjfLHrxdMk6CgAcNV0DG3yhy82iDPBlJGgrJ5D_c_yn6/exec\"; :global MTKURLALT \"https://script.googleusercontent.com/macros/echo?user_content_key=AY5xjrRG_xaaLvHrPKPeJQfDttgv1k8M3BRT97Bf2MpN8AjkXmInstejKwccE9Tu3evg2oFKZ1nK-nhs9YwYQdtaJ_aTSuIK5xpFZ4lWZET-NzhHyIK4mYge99C6GywbUlLvxpK6IZWdOV657ZsKHCTaGfr3On5S9tdOhq_3qXwl0IZJouWUoYric8fowNOJ1T4wNH1g2hWDa38x6scXB_rNDU_-IySH1-a2bcqORNT6pYVEY5fkdy13D8AeYy0MFWzl8u7PIRObcsoITsPSZKF7LQXrBThHSQ&lib=MUG_rLRLoiM7kb_pWjzsTlTi7gexMXnUe\"; :global MTKTOKEN \"MONITOR_TOKEN_2026\"; :global MTKSITE \"KANO\"; :global MTKWANIF \"ether1\"; :global MTKLANIF \"bridge1\"; :global MTKLASTSIG \"\";"

/system script add name=MTK_TEST_FETCH policy=read,write,test source=":global MTKURL; :global MTKURLALT; :global MTKTOKEN; :global MTKSITE; :if ([:len \$MTKURL] = 0) do={ /system script run MTK_CONFIG }; :local u \$MTKURL; :if ([:len \$MTKURLALT] > 0) do={ :set u \$MTKURLALT }; :local d (\"token=\".\$MTKTOKEN); :set d (\$d.\"&type=log\"); :set d (\$d.\"&site=\".\$MTKSITE); :set d (\$d.\"&router=RTR_TEST\"); :set d (\$d.\"&msg=test_fetch\"); :do { /tool fetch url=\$u mode=https check-certificate=no http-method=post http-data=\$d output=none keep-result=no; :put \"MTK_TEST_FETCH_OK\"; :log info \"MTK_TEST_FETCH_OK\"; } on-error={ :put \"MTK_TEST_FETCH_FAIL\"; :log error \"MTK_TEST_FETCH_FAIL\"; };"

/system script add name=MTK_MONITOR_CORE policy=read,write,test source=":global MTKURL; :global MTKURLALT; :global MTKTOKEN; :global MTKSITE; :global MTKWANIF; :global MTKLANIF; :if ([:len \$MTKURL] = 0) do={ /system script run MTK_CONFIG }; :local u \$MTKURL; :if ([:len \$MTKURLALT] > 0) do={ :set u \$MTKURLALT }; :local router [/system identity get name]; :local cpu [/system resource get cpu-load]; :local memfree [/system resource get free-memory]; :local memtotal [/system resource get total-memory]; :local leases [:len [/ip dhcp-server lease find]]; :local hotspotactive [/ip hotspot active print count-only]; :local isp \"DOWN\"; :if ([/ping 8.8.8.8 count=1] > 0) do={ :set isp \"UP\" }; :local ipsec \"DOWN\"; :if ([/ip ipsec active-peers print count-only] > 0) do={ :set ipsec \"UP\" }; :local wanrun \"DOWN\"; :if ([:len [/interface find where name=\$MTKWANIF and running=yes]] > 0) do={ :set wanrun \"UP\" }; :local wanrx 0; :local wantx 0; :if ([:len [/interface find where name=\$MTKWANIF]] > 0) do={ :local wi [/interface find where name=\$MTKWANIF]; :set wanrx [/interface get \$wi rx-byte]; :set wantx [/interface get \$wi tx-byte] }; :local lanrx 0; :local lantx 0; :if ([:len [/interface find where name=\$MTKLANIF]] > 0) do={ :local li [/interface find where name=\$MTKLANIF]; :set lanrx [/interface get \$li rx-byte]; :set lantx [/interface get \$li tx-byte] }; :local d (\"token=\".\$MTKTOKEN); :set d (\$d.\"&type=live\"); :set d (\$d.\"&site=\".\$MTKSITE); :set d (\$d.\"&router=\".\$router); :set d (\$d.\"&cpu=\".\$cpu); :set d (\$d.\"&memfree=\".\$memfree); :set d (\$d.\"&memtotal=\".\$memtotal); :set d (\$d.\"&hotspot_active=\".\$hotspotactive); :set d (\$d.\"&leases=\".\$leases); :set d (\$d.\"&isp=\".\$isp); :set d (\$d.\"&ipsec=\".\$ipsec); :set d (\$d.\"&wan_run=\".\$wanrun); :set d (\$d.\"&isp_rx=\".\$wanrx); :set d (\$d.\"&isp_tx=\".\$wantx); :set d (\$d.\"&lan_rx=\".\$lanrx); :set d (\$d.\"&lan_tx=\".\$lantx); :do { /tool fetch url=\$u mode=https check-certificate=no http-method=post http-data=\$d output=none keep-result=no } on-error={ :log error \"MTK_MONITOR_CORE fetch failed\"; };"

/system script add name=MTK_LOG_PUSH policy=read,write,test source=":global MTKURL; :global MTKURLALT; :global MTKTOKEN; :global MTKSITE; :global MTKLASTSIG; :if ([:len \$MTKURL] = 0) do={ /system script run MTK_CONFIG }; :local u \$MTKURL; :if ([:len \$MTKURLALT] > 0) do={ :set u \$MTKURLALT }; :local router [/system identity get name]; :local rows [/log print as-value where topics~\"critical|error|warning|interface|dhcp|hotspot\"]; :if ([:len \$rows] = 0) do={ :return }; :local lr [:pick \$rows 0]; :local lmsg (\$lr->\"message\"); :if ([:len \"\$lmsg\"] = 0) do={ :set lmsg \"empty\" }; :set lmsg [:pick \$lmsg 0 120]; :local sig ((\$lr->\"time\").\"|\".(\$lr->\"topics\").\"|\".\$lmsg); :if (\$sig = \$MTKLASTSIG) do={ :return }; :set MTKLASTSIG \$sig; :local d (\"token=\".\$MTKTOKEN); :set d (\$d.\"&type=log\"); :set d (\$d.\"&site=\".\$MTKSITE); :set d (\$d.\"&router=\".\$router); :set d (\$d.\"&msg=rlog_\".\$lmsg); :do { /tool fetch url=\$u mode=https check-certificate=no http-method=post http-data=\$d output=none keep-result=no } on-error={ :log error \"MTK_LOG_PUSH fetch failed\"; };"

/system script add name=MTK_EVENT_PUSH policy=read,write,test source=":global MTKURL; :global MTKURLALT; :global MTKTOKEN; :global MTKSITE; :if ([:len \$MTKURL] = 0) do={ /system script run MTK_CONFIG }; :local u \$MTKURL; :if ([:len \$MTKURLALT] > 0) do={ :set u \$MTKURLALT }; :local router [/system identity get name]; :local d (\"token=\".\$MTKTOKEN); :set d (\$d.\"&type=log\"); :set d (\$d.\"&site=\".\$MTKSITE); :set d (\$d.\"&router=\".\$router); :set d (\$d.\"&msg=manual_event\"); :do { /tool fetch url=\$u mode=https check-certificate=no http-method=post http-data=\$d output=none keep-result=no } on-error={ :log error \"MTK_EVENT_PUSH fetch failed\"; };"

/system script add name=MTK_BOOTSTRAP policy=read,write,test source=":delay 1; /system script run MTK_CONFIG; :delay 1; /system script run MTK_TEST_FETCH; :delay 1; /system script run MTK_MONITOR_CORE; :delay 1; /system script run MTK_LOG_PUSH; :delay 1; /system script run MTK_EVENT_PUSH;"

/system scheduler add name=MTK_SCH_CORE on-event=MTK_MONITOR_CORE interval=2m start-time=startup
/system scheduler add name=MTK_SCH_LOG on-event=MTK_LOG_PUSH interval=2m start-time=startup
