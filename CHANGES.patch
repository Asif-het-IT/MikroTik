+function buildTgMsg_(cfg, site, title, mode, d) {
+  const icon = (mode === "ALERT") ? "🚨" : "✅";
+  const fmt = cfgFmt_(cfg);
+  return [
+    `${icon} <b>NOC Team Alert (${escapeHtml_(mode)})</b>`,
